# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
XAI_API_KEY=your-xai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
MOONSHOT_API_KEY=your-moonshot-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Persistent memory embeddings reuse existing model API keys.
# Priority: OpenAI (OPENAI_API_KEY) -> Gemini (GOOGLE_API_KEY) -> Ollama (OLLAMA_BASE_URL)
# No additional memory-specific API keys required.

# Stock Market API Key
FINANCIAL_DATASETS_API_KEY=your-financial-datasets-api-key

# Web Search API Keys (Exa → Perplexity → Tavily → LangSearch)
EXASEARCH_API_KEY=your-exa-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
TAVILY_API_KEY=your-tavily-api-key
LANGSEARCH_API_KEY=your-langsearch-api-key

# X/Twitter API v2 — Module 12 political risk real-time unrest feed (Basic plan $100/mo required)
X_BEARER_TOKEN=your-X-bearer-token

# LangSmith 
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=false

# EODHD (End of Day Historical Data) — FX + IHSG fallback
EODHD_API_KEY=your-eodhd-api-key

# Kemendag EWS SP2KP — Tier 3 PIHPS fallback (register at api.kemendag.go.id)
KEMENDAG_API_KEY=your-kemendag-api-key

# BPS WebAPI — direct BPS data access (free, register at webapi.bps.go.id)
BPS_API_KEY=your-bps-api-key

# Bloomberg B-PIPE REST proxy (optional — free sources used as fallback)
BLOOMBERG_API_URL=https://your-bloomberg-proxy.example.com
BLOOMBERG_API_KEY=your-bloomberg-bearer-token

# LSEG/Refinitiv (optional — free sources used as fallback)
REFINITIV_APP_KEY=your-refinitiv-app-key
REFINITIV_USERNAME=your-refinitiv-username
REFINITIV_PASSWORD=your-refinitiv-password

# BBM domestic fuel price overrides — EMERGENCY USE ONLY
# Set immediately when Pertamina/Kepmen ESDM announces a price hike. No redeploy needed.
# Defaults current as of Jun 10 2026 (Pertamina Patra Niaga announcement).
# PERTALITE_PRICE_IDR=10000
# SOLAR_PRICE_IDR=6800
# PERTAMAX_PRICE_IDR=16250
# PERTAMAX_GREEN_PRICE_IDR=17000

# BI DNDF Outstanding — annual manual update from BI Laporan Keuangan Tahunan (LKT).
# DNDF not in SULNI; not scrapable. Update Mar/Apr each year when BI publishes LKT.
# 2026 H1 estimate (active IDR defense window): $8-12bn.
# BI_DNDF_OUTSTANDING_BN=8.0

# BI Hedging Compliance % — quarterly override when SULNI Playwright + news scrape fail.
# Source: BI quarterly Statistik Utang Luar Negeri Indonesia (SULNI) press release —
#   "rasio kepatuhan pemenuhan kewajiban lindung nilai" (PBI 21/14/2019: min 25%).
# Pin the figure here when health-check shows uln_hedging_compliance_pct = NO DATA.
# Typical Indonesia range: 85-92% (compliance is generally high).
# BI_HEDGING_COMPLIANCE_PCT=88.5

# MSCI Indonesia Classification override — only set if auto-detect fails or you need
# to force a specific status (e.g., for stress simulation).
# Values: confirmed | under_review | downgrade_risk
# Result as of Jun 23 2026: EM CONFIRMED, review extended to Nov 12 2026.
# MSCI_CLASSIFICATION_STATUS=confirmed

# MSCI May 2026 rebalancing outflow — for M5 narrative when known
# MSCI_MAY2026_REBALANCING_OUTFLOW_USD_BN=1.8
